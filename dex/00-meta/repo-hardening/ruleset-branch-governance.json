{
  "_meta": {
    "dex_id": "7E-PROC-01",
    "description": "Ruleset config for work branch governance. Covers feat/*, fix/*, scaffold/*, release/*, hotfix/*.",
    "api_endpoint": "POST /repos/{owner}/{repo}/rulesets",
    "gh_cli": "gh api repos/{owner}/{repo}/rulesets --method POST --input ruleset-branch-governance.json",
    "note": "setup/* is intentionally excluded so bootstrap commits can land without triggering validate check before CI is wired."
  },
  "name": "branch-governance",
  "target": "branch",
  "enforcement": "active",
  "conditions": {
    "ref_name": {
      "include": [
        "refs/heads/scaffold/**",
        "refs/heads/feat/**",
        "refs/heads/fix/**",
        "refs/heads/release/**",
        "refs/heads/hotfix/**"
      ],
      "exclude": []
    }
  },
  "rules": [
    { "type": "non_fast_forward" },
    { "type": "required_linear_history" },
    { "type": "required_signatures" },
    {
      "type": "required_status_checks",
      "parameters": {
        "strict_required_status_checks_policy": false,
        "required_status_checks": [
          { "context": "validate", "integration_id": null }
        ]
      }
    }
  ]
}
